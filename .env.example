# Copy to .env before: docker compose up -d --build

# ---------- Host/NAS routing
# Your NAS LAN IP
HOST_IP=192.168.1.225
# Host port mapped to API container port 4000
API_PORT=4000
# Host port mapped to UI container port 80 (use 8080 to avoid Synology DSM conflicts)
UI_PORT=8080

# ---------- UI (API URL = your NAS, Firebase unchanged)
VITE_API_BASE_URL=http://192.168.1.225:4000
VITE_FIREBASE_API_KEY=AIzaSyCE7rVjUy447l15eRZ_bESwEQs5N0xFC7E
VITE_FIREBASE_AUTH_DOMAIN=camprpg-4919a.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=camprpg-4919a
VITE_FIREBASE_STORAGE_BUCKET=camprpg-4919a.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=603236175475
VITE_FIREBASE_APP_ID=1:603236175475:web:5df7db8cad5c19a2b26406

# ---------- API (optional)
# CORS_ALLOWED_ORIGINS=http://192.168.1.225,http://localhost

HOST=0.0.0.0
PORT=4000
REQUEST_TIMEOUT_MS=10000
POSTGRES_DB=space_case_cruises
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/space_case_cruises
NODE_ENV=development
ALLOW_DB_RESET=false
USE_SUPABASE_AUTH=false
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Security toggles
# When false, x-user-email/x-user-id header auth is disabled
ALLOW_HEADER_AUTH=true
# Comma-separated list of allowed origins for CORS (blank = allow all)
# For production with Cloudflare Tunnel, add your public domain:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=
# Enable rate limiting (recommended in production)
ENABLE_RATE_LIMIT=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Firebase Authentication (Backend)
# For Render etc.: use env vars (no file needed)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or use FIREBASE_SERVICE_ACCOUNT as the full JSON string (legacy)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
