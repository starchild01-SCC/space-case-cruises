{
  "name": "space-case-cruises-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "seed:db": "tsx src/scripts/seed.ts",
    "seed:reset": "tsx src/scripts/seed-reset.ts",
    "generate:client": "openapi-typescript docs/openapi.yaml -o src/generated/api-types.ts",
    "example:client": "tsx src/generated/client.example.ts",
    "test": "vitest run",
    "test:db": "vitest run src/app.postgres.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "openapi-typescript": "^7.5.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
