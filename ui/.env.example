# UI API base URL (required for cross-origin: Hostinger frontend → Render backend)
# Local dev: point to Render production API
# Hostinger build: same value, baked in at build time
VITE_API_BASE_URL=https://space-case-cruises.onrender.com/api/v1

# Firebase Authentication (Frontend)
# Get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
